# --- Required ---

# Google OAuth (Web application credentials from Google Cloud Console).
# OAUTH_REDIRECT_URI must be registered as an authorized redirect URI on
# the same OAuth client and points at the sign-in callback.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_REDIRECT_URI=http://localhost:8000/v1/auth/google/callback

# Pub/Sub topic the Gmail watch publishes to. Format:
# projects/<project>/topics/<topic>
GMAIL_WATCH_TOPIC=

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=emailpartner

# 32 bytes, base64-encoded. Generate with:
#   python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
ENCRYPTION_MASTER_KEY=

# Random secrets. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
OAUTH_STATE_SECRET=
SESSION_SECRET=

# Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# --- Optional ---

# Pub/Sub push subscription token; if set, /v1/webhooks/gmail/?token=... must match.
# PUBSUB_VERIFICATION_TOKEN=

# Admin token for /v1/admin/* endpoints (e.g. manual watch renewal).
# ADMIN_TOKEN=

# Models and limits
# SUMMARY_MODEL=gemini-3.1-flash-lite
# SUMMARY_MAX_BODY_CHARS=8000
# IMAGE_PROVIDER=gemini
# IMAGE_MODEL=gemini-2.5-flash-image           # "Nano Banana" — generate_content path

# Local storage for generated illustrations (swap for cloud later via BlobStorage).
# LOCAL_STORAGE_DIR=./var/illustrations
# LOCAL_STORAGE_PUBLIC_BASE_URL=http://localhost:8000/static/illustrations

# Session cookie
# SESSION_COOKIE_NAME=ep_session
# SESSION_TTL_SECONDS=1209600
# SESSION_COOKIE_SECURE=false  # set true behind HTTPS in production

# Background renewal loop
# ENABLE_BACKGROUND_JOBS=true
# WATCH_RENEW_INTERVAL_SECONDS=3600
# WATCH_RENEW_THRESHOLD_HOURS=24

# Token refresh skew (seconds before access_token expiry to consider it stale).
# TOKEN_REFRESH_SKEW_SECONDS=300

# HTTP client timeout (seconds) for outbound Google calls.
# HTTP_TIMEOUT_SECONDS=10
