<?xml version="1.0" encoding="utf-8"?>
<!-- One card in the swipe deck. The mesh is a Kotlin-drawn (real-blur) bitmap
     rendered at the widget's aspect; text is crisp native TextView. Content is a
     vertical stack (header / phrase fills / footer) so nothing overlaps. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
  android:id="@+id/item_root"
  android:layout_width="match_parent"
  android:layout_height="match_parent">

  <ImageView
    android:id="@+id/item_mesh"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:scaleType="fitXY"
    android:contentDescription="@null" />

  <LinearLayout
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:paddingLeft="16dp"
    android:paddingRight="16dp"
    android:paddingTop="13dp"
    android:paddingBottom="13dp">

    <!-- header: tone dot + sender -->
    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center_vertical">
      <ImageView
        android:id="@+id/item_dot"
        android:layout_width="13dp"
        android:layout_height="13dp"
        android:layout_marginEnd="8dp"
        android:contentDescription="@null" />
      <TextView
        android:id="@+id/item_sender"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxLines="1"
        android:ellipsize="end"
        android:textColor="#E6FFFFFF"
        android:textSize="11sp"
        android:textStyle="bold"
        android:letterSpacing="0.06" />
    </LinearLayout>

    <!-- phrase hero fills the middle, top-aligned -->
    <TextView
      android:id="@+id/item_phrase"
      android:layout_width="match_parent"
      android:layout_height="0dp"
      android:layout_weight="1"
      android:gravity="top"
      android:paddingTop="8dp"
      android:maxLines="3"
      android:ellipsize="end"
      android:textColor="#FFFFFFFF"
      android:textSize="20sp"
      android:textStyle="bold" />

    <!-- footer: play pill + waveform -->
    <LinearLayout
      android:layout_width="wrap_content"
      android:layout_height="wrap_content"
      android:orientation="horizontal"
      android:gravity="center_vertical">
      <LinearLayout
        android:id="@+id/item_pill"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/echo_pill_bg"
        android:paddingLeft="5dp"
        android:paddingRight="12dp"
        android:paddingTop="5dp"
        android:paddingBottom="5dp"
        android:layout_marginEnd="10dp">
        <ImageView
          android:id="@+id/item_play_icon"
          android:layout_width="24dp"
          android:layout_height="24dp"
          android:layout_marginEnd="8dp"
          android:contentDescription="@null" />
        <TextView
          android:id="@+id/item_play_label"
          android:layout_width="wrap_content"
          android:layout_height="wrap_content"
          android:maxLines="1"
          android:textColor="#FFFFFFFF"
          android:textSize="12sp"
          android:textStyle="bold"
          android:text="Listen" />
      </LinearLayout>
      <ImageView
        android:id="@+id/item_wave"
        android:layout_width="wrap_content"
        android:layout_height="18dp"
        android:contentDescription="@null" />
    </LinearLayout>
  </LinearLayout>
</FrameLayout>
